    <connection>EnreachOLTP</connection>
    <sql>SELECT
    u.id_usuario,
    u.nombre,
    u.apellido,
    u.email,
    u.estado AS estado_usuario,
    nd.numero AS numero_did,
    nd.tipo AS tipo_did,
    nd.estado AS estado_did
FROM usuario u
LEFT JOIN numerodid nd
    ON nd.id_usuario = u.id_usuario;</sql>
