    <connection>EnreachOLTP</connection>
    <sql>WITH pago_factura_monto AS (
    SELECT
        p.id_factura,
        SUM(p.monto) AS monto_pagado
    FROM pago p
    WHERE TRIM(UPPER(COALESCE(p.estado, ''))) = 'COMPLETADO'
    GROUP BY p.id_factura
),

pago_factura_ult AS (
    SELECT DISTINCT ON (p.id_factura)
        p.id_factura,
        TRIM(UPPER(COALESCE(p.metodo_pago, 'NO ESPECIFICADO'))) AS metodo_pago
    FROM pago p
    WHERE TRIM(UPPER(COALESCE(p.estado, ''))) = 'COMPLETADO'
    ORDER BY p.id_factura, p.fecha DESC, p.id_pago DESC
),

pago_partner_monto AS (
    SELECT
        pp.id_factura_partner,
        SUM(pp.monto) AS monto_pagado
    FROM pago_partner pp
    WHERE TRIM(UPPER(COALESCE(pp.estado, ''))) = 'COMPLETADO'
    GROUP BY pp.id_factura_partner
),

pago_partner_ult AS (
    SELECT DISTINCT ON (pp.id_factura_partner)
        pp.id_factura_partner,
        TRIM(UPPER(COALESCE(pp.metodo_pago, 'NO ESPECIFICADO'))) AS metodo_pago
    FROM pago_partner pp
    WHERE TRIM(UPPER(COALESCE(pp.estado, ''))) = 'COMPLETADO'
    ORDER BY pp.id_factura_partner, pp.fecha DESC, pp.id_pago_partner DESC
)


SELECT
    NULL::INT AS id_factura_partner,
    f.id_factura,
    NULL::INT AS id_detalle,
    'FACTURA' AS tipo_facturacion,

    f.fecha_emision,
    CAST(f.fecha_emision AS DATE) AS fecha_emision_date,
    EXTRACT(HOUR FROM f.fecha_emision)::INT AS hora_emision,

    co.id_cliente,
    co.id_partner,
    ac.id_acuerdo,
    co.id_contrato,
    co.id_plan,

    co.fecha_inicio AS fecha_inicio_contrato,
    co.fecha_fin AS fecha_fin_contrato,
    ac.fecha_inicio AS fecha_inicio_acuerdo,
    ac.fecha_fin AS fecha_fin_acuerdo,

    TRIM(UPPER(COALESCE(f.estado, 'DESCONOCIDO'))) AS estado_factura,
    TRIM(UPPER(
        CASE
            WHEN TRIM(UPPER(COALESCE(f.estado, ''))) IN ('PENDIENTE', 'VENCIDA')
                THEN 'NO ESPECIFICADO'
            WHEN COALESCE(pfu.metodo_pago, '') = ''
                THEN 'NO ESPECIFICADO'
            ELSE pfu.metodo_pago
        END
    )) AS metodo_pago,

    GREATEST(COALESCE(co.cantidad_plan, 0), 0) AS cantidad,
    GREATEST(COALESCE(pp.precio_mensual, 0), 0) AS precio_unitario,
    GREATEST(COALESCE(f.subtotal, 0), 0) AS subtotal,
    GREATEST(COALESCE(f.descuento, 0), 0) AS descuento,
    GREATEST(COALESCE(f.impuesto_porcentaje, 0), 0) AS impuesto_porcentaje,
    GREATEST(COALESCE(f.impuesto_monto, 0), 0) AS impuesto_monto,
    GREATEST(COALESCE(f.monto_total, 0), 0) AS monto_total_factura,
    GREATEST(COALESCE(pfm.monto_pagado, 0), 0) AS monto_pagado,
    GREATEST(
        GREATEST(COALESCE(f.monto_total, 0), 0) - GREATEST(COALESCE(pfm.monto_pagado, 0), 0),
        0
    ) AS saldo_pendiente,
    CASE
        WHEN f.fecha_emision::DATE &lt; CURRENT_DATE
         AND (
             GREATEST(COALESCE(f.monto_total, 0), 0) - GREATEST(COALESCE(pfm.monto_pagado, 0), 0)
         ) > 0
        THEN CURRENT_DATE - f.fecha_emision::DATE
        ELSE 0
    END AS dias_mora

FROM factura f
JOIN contrato co
    ON f.id_contrato = co.id_contrato
LEFT JOIN plan_producto pp
    ON co.id_plan = pp.id_plan
LEFT JOIN LATERAL (
    SELECT
        ap.id_acuerdo,
        ap.fecha_inicio,
        ap.fecha_fin
    FROM acuerdo_plataforma ap
    WHERE ap.id_partner = co.id_partner
      AND f.fecha_emision::DATE BETWEEN ap.fecha_inicio AND ap.fecha_fin
    ORDER BY ap.fecha_inicio DESC
    LIMIT 1
) ac ON TRUE
LEFT JOIN pago_factura_monto pfm
    ON f.id_factura = pfm.id_factura
LEFT JOIN pago_factura_ult pfu
    ON f.id_factura = pfu.id_factura

UNION ALL

SELECT
    fp.id_factura_partner,
    NULL::INT AS id_factura,
    NULL::INT AS id_detalle,
    'FACTURA_PARTNER' AS tipo_facturacion,

    fp.fecha_emision,
    CAST(fp.fecha_emision AS DATE) AS fecha_emision_date,
    EXTRACT(HOUR FROM fp.fecha_emision)::INT AS hora_emision,

    NULL::INT AS id_cliente,
    ap.id_partner,
    fp.id_acuerdo,
    NULL::INT AS id_contrato,
    NULL::INT AS id_plan,

    NULL::DATE AS fecha_inicio_contrato,
    NULL::DATE AS fecha_fin_contrato,
    ap.fecha_inicio AS fecha_inicio_acuerdo,
    ap.fecha_fin AS fecha_fin_acuerdo,

    TRIM(UPPER(COALESCE(fp.estado, 'DESCONOCIDO'))) AS estado_factura,
    TRIM(UPPER(
        CASE
            WHEN TRIM(UPPER(COALESCE(fp.estado, ''))) IN ('PENDIENTE', 'VENCIDA')
                THEN 'NO ESPECIFICADO'
            WHEN COALESCE(ppu.metodo_pago, '') = ''
                THEN 'NO ESPECIFICADO'
            ELSE ppu.metodo_pago
        END
    )) AS metodo_pago,

    1 AS cantidad,
    GREATEST(COALESCE(fp.monto_total, 0) - COALESCE(fp.impuesto_monto, 0), 0) AS precio_unitario,
    GREATEST(COALESCE(fp.monto_total, 0) - COALESCE(fp.impuesto_monto, 0), 0) AS subtotal,
    0::NUMERIC(10,2) AS descuento,
    GREATEST(COALESCE(fp.impuesto_porcentaje, 0), 0) AS impuesto_porcentaje,
    GREATEST(COALESCE(fp.impuesto_monto, 0), 0) AS impuesto_monto,
    GREATEST(COALESCE(fp.monto_total, 0), 0) AS monto_total_factura,
    GREATEST(COALESCE(ppm.monto_pagado, 0), 0) AS monto_pagado,
    GREATEST(
        GREATEST(COALESCE(fp.monto_total, 0), 0) - GREATEST(COALESCE(ppm.monto_pagado, 0), 0),
        0
    ) AS saldo_pendiente,
    CASE
        WHEN fp.fecha_emision::DATE &lt; CURRENT_DATE
         AND (
             GREATEST(COALESCE(fp.monto_total, 0), 0) - GREATEST(COALESCE(ppm.monto_pagado, 0), 0)
         ) > 0
        THEN CURRENT_DATE - fp.fecha_emision::DATE
        ELSE 0
    END AS dias_mora

FROM factura_partner fp
JOIN acuerdo_plataforma ap
    ON fp.id_acuerdo = ap.id_acuerdo
LEFT JOIN pago_partner_monto ppm
    ON fp.id_factura_partner = ppm.id_factura_partner
LEFT JOIN pago_partner_ult ppu
    ON fp.id_factura_partner = ppu.id_factura_partner;</sql>
