  <step>
    <name>TI_Mensaje_Base</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>EnreachOLTP</connection>
    <sql>WITH entrega_directo_ult AS (
    SELECT DISTINCT ON (ed.id_mensaje_directo)
        ed.id_mensaje_directo,
        TRIM(UPPER(COALESCE(ed.estado, ''))) AS estado
    FROM estado_entrega_directo ed
    ORDER BY ed.id_mensaje_directo, ed.fecha_evento DESC
),

entrega_grupo_resumen AS (
    SELECT
        eg.id_mensaje_grupo,
        BOOL_OR(TRIM(UPPER(COALESCE(eg.estado, ''))) IN ('ENTREGADO', 'LEIDO', 'LEÍDO')) AS fue_entregado
    FROM estado_entrega_grupo eg
    GROUP BY eg.id_mensaje_grupo
)


SELECT
    md.id_mensaje_directo AS id_hecho_origen,
    CAST(md.fecha_envio AS DATE) AS fecha_envio_date,
    EXTRACT(HOUR FROM md.fecha_envio)::INT AS hora_envio,
    co.id_cliente AS bk_cliente,
    co.id_partner AS bk_partner,
    ac.id_acuerdo AS bk_acuerdo,
    co.id_contrato AS bk_contrato,
    co.id_plan AS bk_plan,
    md.id_usuario_origen AS bk_usuario_origen,
    md.id_usuario_destino AS bk_usuario_destino,
    NULL::INT AS bk_grupo,

    COALESCE(LENGTH(md.contenido), 0)::INT AS tamano_bytes,

    ROUND(
        (COALESCE(LENGTH(md.contenido), 0) * 0.01) *
        CASE
            WHEN LOWER(TRIM(COALESCE(md.tipo_contenido, 'texto'))) IN ('imagen', 'image', 'jpg', 'png') THEN 3.0
            WHEN LOWER(TRIM(COALESCE(md.tipo_contenido, 'texto'))) IN ('archivo', 'video', 'audio', 'pdf') THEN 2.0
            ELSE 1.0
        END
    , 2) AS costo_mensaje,

    LOWER(TRIM(COALESCE(md.tipo_contenido, 'texto'))) AS tipo_contenido,
    LOWER(TRIM(COALESCE(md.plataforma_origen, 'desconocido'))) AS plataforma_origen,

    CASE
        WHEN md.url IS NOT NULL AND TRIM(md.url) &lt;&gt; '' THEN TRUE
        ELSE FALSE
    END AS tiene_adjunto,

    CASE
        WHEN md.id_mensaje_original IS NOT NULL THEN TRUE
        ELSE FALSE
    END AS es_respuesta,

    FALSE AS es_grupo,

    CASE
        WHEN ed.estado IN ('ENTREGADO', 'LEIDO', 'LEÍDO') THEN TRUE
        ELSE FALSE
    END AS fue_entregado

FROM mensaje_directo md
JOIN contrato co
    ON co.id_contrato = md.id_contrato
LEFT JOIN entrega_directo_ult ed
    ON ed.id_mensaje_directo = md.id_mensaje_directo
LEFT JOIN LATERAL (
    SELECT ap.id_acuerdo
    FROM acuerdo_plataforma ap
    WHERE ap.id_partner = co.id_partner
      AND md.fecha_envio::DATE BETWEEN ap.fecha_inicio AND ap.fecha_fin
    ORDER BY ap.fecha_inicio DESC
    LIMIT 1
) ac ON TRUE

UNION ALL


SELECT
    mg.id_mensaje_grupo AS id_hecho_origen,
    CAST(mg.fecha_envio AS DATE) AS fecha_envio_date,
    EXTRACT(HOUR FROM mg.fecha_envio)::INT AS hora_envio,
    co.id_cliente AS bk_cliente,
    co.id_partner AS bk_partner,
    ac.id_acuerdo AS bk_acuerdo,
    co.id_contrato AS bk_contrato,
    co.id_plan AS bk_plan,
    mg.id_usuario_origen AS bk_usuario_origen,
    NULL::INT AS bk_usuario_destino,
    mg.id_grupo_destino AS bk_grupo,

    COALESCE(LENGTH(mg.contenido), 0)::INT AS tamano_bytes,

    ROUND(
        (COALESCE(LENGTH(mg.contenido), 0) * 0.01) *
        CASE
            WHEN LOWER(TRIM(COALESCE(mg.tipo_contenido, 'texto'))) IN ('imagen', 'image', 'jpg', 'png') THEN 3.0
            WHEN LOWER(TRIM(COALESCE(mg.tipo_contenido, 'texto'))) IN ('archivo', 'video', 'audio', 'pdf') THEN 2.0
            ELSE 1.0
        END
    , 2) AS costo_mensaje,

    LOWER(TRIM(COALESCE(mg.tipo_contenido, 'texto'))) AS tipo_contenido,
    LOWER(TRIM(COALESCE(mg.plataforma_origen, 'desconocido'))) AS plataforma_origen,

    CASE
        WHEN mg.url IS NOT NULL AND TRIM(mg.url) &lt;&gt; '' THEN TRUE
        ELSE FALSE
    END AS tiene_adjunto,

    CASE
        WHEN mg.id_mensaje_original IS NOT NULL THEN TRUE
        ELSE FALSE
    END AS es_respuesta,

    TRUE AS es_grupo,

    COALESCE(egr.fue_entregado, FALSE) AS fue_entregado

FROM mensaje_grupo mg
JOIN contrato co
    ON co.id_contrato = mg.id_contrato
LEFT JOIN entrega_grupo_resumen egr
    ON egr.id_mensaje_grupo = mg.id_mensaje_grupo
LEFT JOIN LATERAL (
    SELECT ap.id_acuerdo
    FROM acuerdo_plataforma ap
    WHERE ap.id_partner = co.id_partner
      AND mg.fecha_envio::DATE BETWEEN ap.fecha_inicio AND ap.fecha_fin
    ORDER BY ap.fecha_inicio DESC
    LIMIT 1
) ac ON TRUE;</sql>
