  <step>
    <name>TI_Cliente_Base</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>EnreachOLTP</connection>
    <sql>SELECT
    c.id_cliente,
    f.id_filial,
    c.razon_social,
    c.identificador_fiscal,
    c.dominio_tenant,
    c.timezone,
    c.pais_sede,
    c.ciudad_sede,
    c.fecha_alta,
    c.estado AS estado_cliente,
    f.nombre AS nombre_filial,
    f.pais AS pais_filial,
    f.ciudad AS ciudad_filial,
    f.direccion AS direccion_filial,
    f.estado AS estado_filial,
    e.numero_extension,
    e.tipo AS tipo_extension,
    CASE
        WHEN UPPER(TRIM(e.estado)) IN ('ACTIVO', 'ACTIV') THEN 'ACTIVO'
        WHEN UPPER(TRIM(e.estado)) IN ('SUSPENDIDO', 'SUSPENDID') THEN 'SUSPENDIDO'
        WHEN UPPER(TRIM(e.estado)) IN ('INACTIVO', 'INACTIV') THEN 'INACTIVO'
        WHEN UPPER(TRIM(e.estado)) IN ('ASIGNADO', 'ASIGNAD') THEN 'ASIGNADO'
        ELSE UPPER(TRIM(e.estado))
    END AS estado_extension
FROM cliente c
LEFT JOIN filial f
    ON f.id_cliente = c.id_cliente
LEFT JOIN extension e
    ON e.id_cliente = c.id_cliente;</sql>
